{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/jobs/overnight-prep", "schedule": "0 2 * * 1-5" },
    { "path": "/api/discovery/run", "schedule": "5 9 * * 1-5" },
    { "path": "/api/jobs/pre-market", "schedule": "10 9 * * 1-5" },
    { "path": "/api/jobs/news-refresh", "schedule": "30 9-16 * * 1-5" },
    { "path": "/api/jobs/eod-report", "schedule": "45 15 * * 1-5" },
    { "path": "/api/jobs/evening-digest", "schedule": "0 18 * * 1-5" },
    { "path": "/api/jobs/news-refresh", "schedule": "0 20 * * 1-5" },
    { "path": "/api/jobs/news-purge", "schedule": "0 23 * * *" }
  ]
}
