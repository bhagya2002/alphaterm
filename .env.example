# =============================================================================
# AlphaTerm — Environment variables. Copy to .env.local and fill in values.
# Get API keys from the links below (open in browser to sign up / create key).
# =============================================================================

# --- Auth (required) ---
APP_PIN=000000
# 6-digit PIN for app access. Choose your own.

JWT_SECRET=your-32-char-minimum-random-secret-here
# Generate: openssl rand -base64 32

# --- Supabase (required) ---
# Dashboard: https://supabase.com/dashboard — create project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Market data ---
# Finnhub: https://finnhub.io/register — free tier, 60 req/min
FINNHUB_API_KEY=

# Alpha Vantage: https://www.alphavantage.co/support/#api-key — 5 req/min, 500/day
ALPHA_VANTAGE_KEY=

# Financial Modeling Prep: https://site.financialmodelingprep.com/developer/docs — 250 req/day
FMP_API_KEY=

# Polygon: https://polygon.io/dashboard/signup — free tier (delayed data)
POLYGON_KEY=

# --- News ---
# NewsAPI: https://newsapi.org/register — 100 req/day free
NEWSAPI_KEY=

# Marketaux: https://www.marketaux.com/ — free tier
MARKETAUX_KEY=

# --- LLM providers (use at least 2–3 for rotation) ---
# Groq: https://console.groq.com/ — free tier (Llama 3.1 8B, 3.3 70B)
GROQ_API_KEY=

# Cerebras: https://cloud.cerebras.ai/ — free tier (Llama 3.1 8B, 3.3 70B)
CEREBRAS_API_KEY=

# Google AI Studio: https://aistudio.google.com/app/apikey — Gemini free tier
GOOGLE_AI_KEY=

# OpenRouter: https://openrouter.ai/keys — 50 free req/day (1,000 with one-time $10)
OPENROUTER_API_KEY=

# Mistral: https://console.mistral.ai/ — La Plateforme free tier (1B tokens/month)
MISTRAL_API_KEY=

# GitHub Models (Copilot): https://github.com/settings/tokens — for GitHub Models API
GITHUB_MODELS_TOKEN=

# NVIDIA NIMS: https://console.nvidia.com/nims/ — free tier (40 req/minute)
NVIDIA_NIMS_API_KEY=

# --- Cron (recommended for production) ---
# Set a random secret; Vercel Cron will send it when invoking job endpoints.
# https://vercel.com/docs/cron-jobs
CRON_SECRET=
ALPHATERM_URL=
Vercel app URL (e.g. https://alphaterm-xxx.vercel.app)

# --- Optional / Phase 3+ ---
# Bank of Canada Valet: no key — https://www.bankofcanada.com/valet/docs/
# FRED (Federal Reserve): https://fred.stlouisfed.org/docs/api/api_key.html — 2500 req/day
FRED_API_KEY=

# --- Optional / Phase 4+ ---
# SEC EDGER: use a descriptive User-Agent (no key). https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=your-name-contact@domain.com

# Embeddings (semantic search): uses OPENROUTER_API_KEY; override model if needed.
EMBEDDING_MODEL=text-embedding-3-large

# --- API on Render (when frontend is on Vercel) — set in Render dashboard ---
# CORS_ORIGIN=https://alphaterm.vercel.app
# COOKIE_SAMESITE=None

# --- Frontend: point to external API (set in Vercel when API is on Render) ---
# VITE_API_URL=https://alphaterm-api.onrender.com

# --- Frontend (optional; same Supabase project for client-side) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# Quick links to create API keys (open in browser)
# =============================================================================
# Supabase:     https://supabase.com/dashboard
# Finnhub:      https://finnhub.io/register
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# FMP:          https://site.financialmodelingprep.com/developer/docs
# Polygon:      https://polygon.io/dashboard/signup
# NewsAPI:      https://newsapi.org/register
# Marketaux:    https://www.marketaux.com/
# Groq:         https://console.groq.com/
# Cerebras:     https://cloud.cerebras.ai/
# Google AI:    https://aistudio.google.com/app/apikey
# OpenRouter:   https://openrouter.ai/keys
# Mistral:      https://console.mistral.ai/
# GitHub token: https://github.com/settings/tokens
# FRED:         https://fred.stlouisfed.org/docs/api/api_key.html
# Bank of Canada (no key): https://www.bankofcanada.com/valet/docs/
# SEC EDGAR (no key):      https://www.sec.gov/os/accessing-edgar-data
